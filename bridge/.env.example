# ブリッジサーバー設定

# ブリッジ認証キー（worker/.dev.vars の BRIDGE_SECRET と同じ値）
BRIDGE_SECRET=your-bridge-secret

# ブリッジサーバーのポート
PORT=3456

# プロジェクトのスキャン対象ディレクトリ（絶対パス）
# Claudeに操作させたいプロジェクトが入っているフォルダを指定します
# 例（Windows）: C:\Users\YourName\projects
# 例（Mac/Linux）: /home/yourname/projects
# 未設定の場合は bridge/ の2階層上のディレクトリが使用されます（非推奨）
PROJECTS_DIR=

# WorkerのURL（CORS許可用）
# ローカルモード: 不要（デフォルトで localhost:8787 を許可）
# Cloudflareフリー枠: https://your-project.your-subdomain.workers.dev
# カスタムドメイン: https://your-api.your-domain.com
WORKER_URL=

# フロントエンドのURL（WebSocket Origin認証用）
# ローカルモード: 不要（デフォルトで localhost:5173 を許可）
# Cloudflareフリー枠: https://your-project.pages.dev
# カスタムドメイン: https://your-frontend.your-domain.com
FRONTEND_URL=
