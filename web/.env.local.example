# フロントエンド環境変数

# Worker認証キー（worker/.dev.vars の API_KEY と同じ値）
VITE_API_KEY=your-api-key

# --- ローカルモード（デフォルト）---
# コメントアウトのままでOK（vite dev 時は localhost が使われる）

# --- Cloudflareフリー枠モード ---
# VITE_API_BASE=https://your-project.your-subdomain.workers.dev/api
# VITE_BRIDGE_HTTP_BASE=https://your-tunnel-name.cfargotunnel.com

# --- カスタムドメインモード ---
# VITE_API_BASE=https://your-api.your-domain.com/api
# VITE_BRIDGE_HTTP_BASE=https://your-bridge.your-domain.com
